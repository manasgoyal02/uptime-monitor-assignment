# Database connection string for MongoDB
# For a standard local MongoDB server running on localhost:
DATABASE_URL=

# For running within Docker Compose (which uses a replicaSet):
# DATABASE_URL=mongodb://db:27017/uptime_db?replicaSet=rs0

# Port the backend API will listen on
PORT=

# Cron schedule for health checks (defaults to every minute)
CRON_SCHEDULE=* * * * *

# Health check request timeout in milliseconds (defaults to 10000ms)
REQUEST_TIMEOUT=
